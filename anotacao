    let index = 0;
const slider = document.getElementById("sliderDepoimentos");
const slides = document.querySelectorAll(".slide");

function moverSlide(){
    index++;
    if(index >= slides.length) index = 0;
    slider.style.transform = `translateX(-${index * 100}%)`;
}

setInterval(moverSlide, 4000);
/* =================================
DEPOIMENTOS SLIDER (FINAL)
================================= */

.depoimentos{
    padding: 80px 15px;
    background: #fafafa;
}

/* HEADER */
.depoimentos-header{
    text-align: center;
    margin-bottom: 30px;
}

.depoimentos-header h2{
    font-size: 28px;
    margin: 10px 0;
}

.depoimentos-header p{
    color: #666;
    max-width: 500px;
    margin: auto;
    font-size: 14px;
}

/* CONTAINER */
.slider-container{
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    overflow: hidden;
    position: relative;
}

/* TRACK */
.slider{
    display: flex;
    transition: transform 0.4s ease;
}

/* SLIDE */
.slide{
    min-width: 100%;
    display: flex;
    justify-content: center;
}

/* CARD */
.depoimento-card{
    width: 100%;
    max-width: 100%;
    background: #fff;
    padding: 20px;
    border-radius: 14px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}

/* ESTRELAS */
.estrelas{
    color: #f4b400;
    margin-bottom: 10px;
}

/* TEXTO */
.depoimento-card p{
    font-size: 14px;
    color: #444;
    line-height: 1.5;
    margin-bottom: 15px;
}

/* ALUNA */
.depoimento-aluna{
    display: flex;
    align-items: center;
    gap: 10px;
}

/* FOTO PERFIL */
.depoimento-aluna img:first-child{
    width: 45px;
    height: 45px;
    border-radius: 50%;
    object-fit: cover;
}

/* TEXTO NOME */
.depoimento-aluna strong{
    font-size: 14px;
}

.depoimento-aluna span{
    font-size: 12px;
    color: #777;
}

/* IMAGEM EXTRA (UNHA) */
.depoimento-aluna img:last-child{
    width: 55px;
    height: 55px;
    border-radius: 8px;
    margin-left: auto;
}

/* DOTS */
.slider-dots{
    display: flex;
    justify-content: center;
    margin-top: 15px;
    gap: 8px;
}

.slider-dots span{
    width: 8px;
    height: 8px;
    background: #ddd;
    border-radius: 50%;
    cursor: pointer;
}

.slider-dots span.active{
    background: #c5a46d;
    transform: scale(1.2);
}

/* =================================
RESPONSIVO MOBILE
================================= */

@media (max-width: 768px){

    .depoimentos{
        padding: 60px 10px;
    }

    .depoimentos-header h2{
        font-size: 22px;
    }

    .depoimento-card{
        padding: 16px;
    }

    .depoimento-card p{
        font-size: 13px;

        /* corta texto grande */
        display: -webkit-box;
        -webkit-line-clamp: 5;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

}

/* 🔥 ESSENCIAL (corrige corte lateral) */
*{
    box-sizing: border-box;
}
*{
    outline: 1px solid red;
}
body{
    overflow-x: hidden;
}